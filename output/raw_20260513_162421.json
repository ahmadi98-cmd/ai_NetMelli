**یک نمونه کامل — “فروشگاه تک صفحه”**  
(HTML + CSS + JS، بدون نیاز به backend)

> ⚡️ **نکته**: این کد فقط برای نمونه است. در محیط واقعی باید امنیت، پرداخت، و ذخیره‌سازی سمت سرور را اضافه کنید.

```html
<!DOCTYPE html>
<html lang="fa" dir="rtl">
<head>
<meta charset="UTF-8">
<title>فروشگاه تک صفحه</title>
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<style>
  /* --------------------  پایه  -------------------- */
  body{font-family:Tahoma,Arial,sans-serif;margin:0;background:#f4f4f4;color:#333;}
  h1{margin:0;font-size:1.8rem;text-align:center;}
  a{color:inherit;text-decoration:none;}
  button{cursor:pointer;}
  /* ---------------  نوار بالا  --------------- */
  header{
    background:#1e90ff;color:#fff;
    padding:1rem 2rem;display:flex;align-items:center;justify-content:space-between;
  }
  .logo{font-weight:bold;font-size:1.3rem;}
  .search-bar input{
    padding:.5rem 1rem;border:none;border-radius:5px;
  }
  .cart-btn{
    position:relative;display:flex;align-items:center;
  }
  .cart-btn span{margin-left:.5rem;}
  .cart-badge{
    position:absolute;top:-5px;right:-5px;background:#ff5c5c;color:#fff;
    width:18px;height:18px;border-radius:50%;display:flex;align-items:center;justify-content:center;font-size:.8rem;
  }
  /* ---------------  محصولات  --------------- */
  .products{display:grid;gap:1rem;grid-template-columns:repeat(auto-fit,minmax(200px,1fr));padding:2rem;}
  .product-card{
    background:#fff;border-radius:8px;overflow:hidden;
    box-shadow:0 2px 5px rgba(0,0,0,.1);display:flex;flex-direction:column;
  }
  .product-card img{width:100%;height:160px;object-fit:cover;}
  .product-info{padding:1rem;flex:1;}
  .product-info h3{margin:0;font-size:1rem;color:#333;}
  .price{color:#e74c3c;font-weight:bold;margin:.5rem 0;}
  .add-btn{background:#1e90ff;color:#fff;border:none;padding:.5rem 1rem;border-radius:5px;width:100%;}
  /* ---------------  سبد خرید  --------------- */
  .cart{
    position:fixed;top:0;right:-400px;width:350px;height:100%;background:#fff;box-shadow:-2px 0 5px rgba(0,0,0,.3);
    transition:right .3s ease;display:flex;flex-direction:column;
  }
  .cart.open{right:0;}
  .cart-header{background:#1e90ff;color:#fff;padding:1rem;font-size:1.2rem;display:flex;justify-content:space-between;align-items:center;}
  .cart-items{flex:1;overflow-y:auto;padding:1rem;}
  .cart-item{display:flex;align-items:center;margin-bottom:1rem;}
  .cart-item img{width:50px;height:50px;border-radius:5px;margin-right:.5rem;}
  .cart-item-info{flex:1;}
  .cart-item-info h4{margin:0;font-size:.9rem;}
  .cart-item-info p{margin:0;font-size:.8rem;color:#777;}
  .cart-footer{padding:1rem;border-top:1px solid #ddd;}
  .cart-footer p{margin:0;font-weight:bold;}
  .close-cart{cursor:pointer;font-size:1.5rem;}
  /* ---------------  موبایل  --------------- */
  @media(max-width:600px){
    .cart{width:100%;}
    header{flex-direction:column;gap:.5rem;}
    .search-bar{width:100%;}
  }
</style>
</head>
<body>
<header>
  <div class="logo">فروشگاه آنلاین</div>
  <div class="search-bar">
    <input type="text" id="search" placeholder="جستجو..." />
  </div>
  <div class="cart-btn" id="cartBtn">
    <i>🛒</i>
    <span>سبد خرید</span>
    <div class="cart-badge" id="cartCount">0</div>
  </div>
</header>

<main>
  <section class="products" id="productList"></section>
</main>

<!-- سبد خرید -->
<div class="cart" id="cart">
  <div class="cart-header">
    <span>سبد خرید</span>
    <span class="close-cart" id="closeCart">&times;</span>
  </div>
  <div class="cart-items" id="cartItems"></div>
  <div class="cart-footer">
    <p>جمع کل: <span id="totalPrice">0</span> تومان</p>
  </div>
</div>

<script>
  /* ========================  داده‌ی محصولات  ======================== */
  const products = [
    {id:1, name:"کیف چرمی",